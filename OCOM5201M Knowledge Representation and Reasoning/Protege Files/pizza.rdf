<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.worg/wesle/ontologies/2023/5/untitled-ontology-11/"
     xml:base="http://www.semanticweb.worg/wesle/ontologies/2023/5/untitled-ontology-11/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:pizza="https://www.pizza.com/ontologies/pizza.owl#">
    <owl:Ontology rdf:about="https://www.pizza.com/ontologies/pizza.owl">
        <rdfs:comment xml:lang="en">This ontology describes a pizza - a result of some panicked exercises done before an assessment</rdfs:comment>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://www.pizza.com/ontologies/pizza.owl#hasBase -->

    <owl:ObjectProperty rdf:about="https://www.pizza.com/ontologies/pizza.owl#hasBase">
        <rdfs:subPropertyOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasIngredient"/>
        <owl:inverseOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#isBaseOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://www.pizza.com/ontologies/pizza.owl#Pizza"/>
        <rdfs:range rdf:resource="https://www.pizza.com/ontologies/pizza.owl#PizzaBase"/>
    </owl:ObjectProperty>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#hasCountryOfOrigin -->

    <owl:ObjectProperty rdf:about="https://www.pizza.com/ontologies/pizza.owl#hasCountryOfOrigin"/>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#hasIngredient -->

    <owl:ObjectProperty rdf:about="https://www.pizza.com/ontologies/pizza.owl#hasIngredient">
        <owl:inverseOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#isIngredientOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    </owl:ObjectProperty>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#hasSpiciness -->

    <owl:ObjectProperty rdf:about="https://www.pizza.com/ontologies/pizza.owl#hasSpiciness">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:range rdf:resource="https://www.pizza.com/ontologies/pizza.owl#SpicinessValuePartition"/>
    </owl:ObjectProperty>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#hasTopping -->

    <owl:ObjectProperty rdf:about="https://www.pizza.com/ontologies/pizza.owl#hasTopping">
        <rdfs:subPropertyOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasIngredient"/>
        <owl:inverseOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#isToppingOf"/>
        <rdfs:domain rdf:resource="https://www.pizza.com/ontologies/pizza.owl#Pizza"/>
        <rdfs:range rdf:resource="https://www.pizza.com/ontologies/pizza.owl#PizzaTopping"/>
    </owl:ObjectProperty>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#isBaseOf -->

    <owl:ObjectProperty rdf:about="https://www.pizza.com/ontologies/pizza.owl#isBaseOf">
        <rdfs:subPropertyOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#isIngredientOf"/>
        <rdfs:domain rdf:resource="https://www.pizza.com/ontologies/pizza.owl#PizzaBase"/>
        <rdfs:range rdf:resource="https://www.pizza.com/ontologies/pizza.owl#Pizza"/>
    </owl:ObjectProperty>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#isIngredientOf -->

    <owl:ObjectProperty rdf:about="https://www.pizza.com/ontologies/pizza.owl#isIngredientOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    </owl:ObjectProperty>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#isToppingOf -->

    <owl:ObjectProperty rdf:about="https://www.pizza.com/ontologies/pizza.owl#isToppingOf">
        <rdfs:subPropertyOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#isIngredientOf"/>
        <rdfs:domain rdf:resource="https://www.pizza.com/ontologies/pizza.owl#PizzaTopping"/>
        <rdfs:range rdf:resource="https://www.pizza.com/ontologies/pizza.owl#Pizza"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://www.pizza.com/ontologies/pizza.owl#hasCalorificContentValue -->

    <owl:DatatypeProperty rdf:about="https://www.pizza.com/ontologies/pizza.owl#hasCalorificContentValue">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://www.pizza.com/ontologies/pizza.owl#AmericanHotPizza -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#AmericanHotPizza">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#NamedPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasTopping"/>
                <owl:someValuesFrom rdf:resource="https://www.pizza.com/ontologies/pizza.owl#JalapenoPepperTopping"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasTopping"/>
                <owl:someValuesFrom rdf:resource="https://www.pizza.com/ontologies/pizza.owl#MozzarellaTopping"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasTopping"/>
                <owl:someValuesFrom rdf:resource="https://www.pizza.com/ontologies/pizza.owl#PepperoniTopping"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasTopping"/>
                <owl:someValuesFrom rdf:resource="https://www.pizza.com/ontologies/pizza.owl#TomatoTopping"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasTopping"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://www.pizza.com/ontologies/pizza.owl#JalapenoPepperTopping"/>
                            <rdf:Description rdf:about="https://www.pizza.com/ontologies/pizza.owl#MozzarellaTopping"/>
                            <rdf:Description rdf:about="https://www.pizza.com/ontologies/pizza.owl#PepperoniTopping"/>
                            <rdf:Description rdf:about="https://www.pizza.com/ontologies/pizza.owl#TomatoTopping"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A pizza that only has Jalapeno, pepperoni, mozzarella and tomato toppings</rdfs:comment>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#AmericanaPizza -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#AmericanaPizza">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#NamedPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasTopping"/>
                <owl:someValuesFrom rdf:resource="https://www.pizza.com/ontologies/pizza.owl#MozzarellaTopping"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasTopping"/>
                <owl:someValuesFrom rdf:resource="https://www.pizza.com/ontologies/pizza.owl#PepperoniTopping"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasTopping"/>
                <owl:someValuesFrom rdf:resource="https://www.pizza.com/ontologies/pizza.owl#TomatoTopping"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasTopping"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://www.pizza.com/ontologies/pizza.owl#MozzarellaTopping"/>
                            <rdf:Description rdf:about="https://www.pizza.com/ontologies/pizza.owl#PepperoniTopping"/>
                            <rdf:Description rdf:about="https://www.pizza.com/ontologies/pizza.owl#TomatoTopping"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A pizza that only has pepperoni, mozzarella and tomato toppings</rdfs:comment>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#AnchovyTopping -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#AnchovyTopping">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#SeafoodTopping"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasSpiciness"/>
                <owl:someValuesFrom rdf:resource="https://www.pizza.com/ontologies/pizza.owl#Mild"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#CaperTopping -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#CaperTopping">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#VegetableTopping"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasSpiciness"/>
                <owl:someValuesFrom rdf:resource="https://www.pizza.com/ontologies/pizza.owl#Mild"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#CheeseTopping -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#CheeseTopping">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#PizzaTopping"/>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#CheesyPizza -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#CheesyPizza">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.pizza.com/ontologies/pizza.owl#Pizza"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasTopping"/>
                        <owl:someValuesFrom rdf:resource="https://www.pizza.com/ontologies/pizza.owl#CheeseTopping"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#Country -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#Country"/>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#DeepPanBase -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#DeepPanBase">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#PizzaBase"/>
        <owl:disjointWith rdf:resource="https://www.pizza.com/ontologies/pizza.owl#ThinAndCrispyBase"/>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#FourCheesePizza -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#FourCheesePizza">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#NamedPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasTopping"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">4</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://www.pizza.com/ontologies/pizza.owl#CheeseTopping"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#GreenPepperTopping -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#GreenPepperTopping">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#PepperTopping"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasSpiciness"/>
                <owl:someValuesFrom rdf:resource="https://www.pizza.com/ontologies/pizza.owl#Mild"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#HamTopping -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#HamTopping">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#MeatTopping"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasSpiciness"/>
                <owl:someValuesFrom rdf:resource="https://www.pizza.com/ontologies/pizza.owl#Mild"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#HighCaloriePizza -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#HighCaloriePizza">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.pizza.com/ontologies/pizza.owl#Pizza"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasCalorificContentValue"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">400</xsd:minInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#Hot -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#Hot">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#SpicinessValuePartition"/>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#InterestingPizza -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#InterestingPizza">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.pizza.com/ontologies/pizza.owl#Pizza"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasTopping"/>
                        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">3</owl:minCardinality>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#JalapenoPepperTopping -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#JalapenoPepperTopping">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#PepperTopping"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasSpiciness"/>
                <owl:someValuesFrom rdf:resource="https://www.pizza.com/ontologies/pizza.owl#Hot"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#LowCaloriePizza -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#LowCaloriePizza">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.pizza.com/ontologies/pizza.owl#Pizza"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasCalorificContentValue"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">400</xsd:maxExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#MargheritaPizza -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#MargheritaPizza">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#NamedPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasTopping"/>
                <owl:someValuesFrom rdf:resource="https://www.pizza.com/ontologies/pizza.owl#MozzarellaTopping"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasTopping"/>
                <owl:someValuesFrom rdf:resource="https://www.pizza.com/ontologies/pizza.owl#TomatoTopping"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasTopping"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://www.pizza.com/ontologies/pizza.owl#MozzarellaTopping"/>
                            <rdf:Description rdf:about="https://www.pizza.com/ontologies/pizza.owl#TomatoTopping"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A pizza that only has mozzarella and tomato toppings</rdfs:comment>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#MeatTopping -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#MeatTopping">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#PizzaTopping"/>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#Medium -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#Medium">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#SpicinessValuePartition"/>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#Mild -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#Mild">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#SpicinessValuePartition"/>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#MozzarellaTopping -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#MozzarellaTopping">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#CheeseTopping"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasSpiciness"/>
                <owl:someValuesFrom rdf:resource="https://www.pizza.com/ontologies/pizza.owl#Mild"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasCountryOfOrigin"/>
                <owl:hasValue rdf:resource="https://www.pizza.com/ontologies/pizza.owl#Italy"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://www.pizza.com/ontologies/pizza.owl#ParmesanTopping"/>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#MushroomTopping -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#MushroomTopping">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#VegetableTopping"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.pizza.com/ontologies/pizza.owl#hasSpiciness"/>
                <owl:someValuesFrom rdf:resource="https://www.pizza.com/ontologies/pizza.owl#Mild"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#NamedPizza -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#NamedPizza">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#Pizza"/>
    </owl:Class>
    


    <!-- https://www.pizza.com/ontologies/pizza.owl#OliveTopping -->

    <owl:Class rdf:about="https://www.pizza.com/ontologies/pizza.owl#OliveTopping">
        <rdfs:subClassOf rdf:resource="https://www.pizza.com/ontologies/pizza.owl#VegetableTopping"/>
        <rdfs:subClassOf>
            <owl:Restriction>
